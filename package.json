{
  "name": "react-native-echarts",
  "version": "3.0.1",
  "description": "Echarts for React Native.",
  "main": "index.ts",
  "packageManager": "yarn@4.13.0",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "skiaChart.*",
    "svgChart.*",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "test": "jest",
    "type-check": "tsc --noEmit",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "release": "release-it --only-version"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "devDependencies": {
    "@commitlint/config-conventional": "^19.8.1",
    "@react-native/babel-preset": "0.81.1",
    "@react-native/eslint-config": "^0.81.1",
    "@release-it/conventional-changelog": "^10.0.1",
    "@shopify/react-native-skia": "2.2.12",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.12",
    "@types/react-test-renderer": "19.1.0",
    "commitlint": "^19.8.1",
    "del-cli": "^6.0.0",
    "echarts": "^6.0.0",
    "jest": "^29.7.0",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-builder-bob": "^0.40.13",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-svg": "15.12.1",
    "react-test-renderer": "19.1.0",
    "release-it": "^19.0.4",
    "typescript": "^5.9.2",
    "zrender": "^6.0.0"
  },
  "peerDependencies": {
    "@shopify/react-native-skia": "*",
    "echarts": "*",
    "react": "*",
    "react-native": "*",
    "react-native-gesture-handler": "*",
    "react-native-svg": "*",
    "zrender": "*"
  },
  "peerDependenciesMeta": {
    "@shopify/react-native-skia": {
      "optional": true
    },
    "react-native-gesture-handler": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    }
  },
  "resolutions": {
    "tslib": "^2.6.1"
  },
  "workspaces": [
    "example"
  ],
  "dependencies": {
    "@xmldom/xmldom": "^0.8.6",
    "entities": "^4.4.0"
  }
}
